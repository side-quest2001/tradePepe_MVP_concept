{
  "name": "tradepepe-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "nodemon --watch src --ext ts --exec \"tsx src/server.ts\"",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "docker:dev": "sh -c 'until node -e \"const net=require(\\\"node:net\\\"); const socket=net.connect({host: process.env.DB_HOST || \\\"postgres\\\", port: Number(process.env.DB_PORT || 5432)}, () => { socket.end(); process.exit(0); }); socket.on(\\\"error\\\", () => process.exit(1)); setTimeout(() => process.exit(1), 1000);\"; do echo \"Waiting for postgres...\"; sleep 2; done; npm run dev'",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:seed": "tsx src/db/seed.ts"
  },
  "dependencies": {
    "cloudinary": "^2.9.0",
    "cors": "^2.8.5",
    "csv-parse": "^5.5.6",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.44.0",
    "express": "^4.21.2",
    "helmet": "^8.1.0",
    "multer": "^2.0.2",
    "pino": "^9.7.0",
    "pino-http": "^10.5.0",
    "postgres": "^3.4.7",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.3",
    "@types/multer": "^2.0.0",
    "@types/node": "^24.6.0",
    "@types/supertest": "^6.0.3",
    "drizzle-kit": "^0.31.4",
    "nodemon": "^3.1.14",
    "pino-pretty": "^13.1.1",
    "supertest": "^7.1.4",
    "tsx": "^4.20.5",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
